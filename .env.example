# Deployment: private key without the 0x prefix. Never commit a funded key.
DEPLOYER_PRIVATE_KEY=
# Deployment: wallet receiving platform fees and resolving MVP disputes.
FEE_COLLECTOR_ADDRESS=
# Deployment: official Circle USDC address on Base Sepolia.
USDC_ADDRESS=
# Deployment: RPC endpoint and Basescan verification key.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=
# Optional only for a private/local test network when no official USDC is used.
DEPLOY_MOCK_USDC=false

# Frontend: copy to web/.env.local after deployment.
NEXT_PUBLIC_PROBLEM_MARKET_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_SUBGRAPH_URL=
# Cloudflare Worker upload endpoint used by the production client.
NEXT_PUBLIC_IPFS_API_URL=https://problemarket-ipfs-api.mariano-906.workers.dev

# IPFS: required for persistent production content.
PINATA_JWT=
# Development only: true permits plaintext/JSON on-chain when Pinata is absent.
NEXT_PUBLIC_DEV_MODE=false

# Cloudflare deployment metadata (do not place API tokens here).
CLOUDFLARE_ACCOUNT_ID=
